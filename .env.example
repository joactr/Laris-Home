# ---# AI & Search configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-3.5-turbo
VOICE_RECIPE_DB_LIMIT=10
VOICE_RECIPE_SUGGESTION_LIMIT=3

# --- Push Notifications Configuration ---
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:your_email@example.com

# --- Voice Assistant (Deepgram) Configuration ---
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_LANGUAGE=es
DEEPGRAM_ENDPOINTING=2000

# --- Server Configuration ---
# Docker Compose will use host.docker.internal automatically, this is for local fallback
DATABASE_URL=postgres://larishome:larishome@localhost:5432/larishome
JWT_SECRET=supersecretjwtkey_changeme
PORT=4000

# --- Automated Postgres Backups ---
DB_BACKUP_DATABASE=larishome
DB_BACKUP_USER=larishome
DB_BACKUP_PASSWORD=larishome
DB_BACKUP_INTERVAL_SECONDS=86400
DB_BACKUP_RETENTION_DAYS=7
