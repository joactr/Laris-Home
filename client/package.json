        "zustand": "^4.5.2"
    },
    "devDependencies": {
        "@types/react": "^18.3.1",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^4.2.1",
        "@playwright/test": "^1.54.0",
        "typescript": "^5.4.5",
        "vite": "^5.2.10"
    }
